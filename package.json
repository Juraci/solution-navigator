{
  "name": "solution-navigator",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "npm": ">=11.0.0 <12.0.0",
    "node": ">=24.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview --port 5173",
    "test:unit": "vitest --run",
    "test:e2e": "start-server-and-test preview http://localhost:5173 'cypress run --headed'",
    "test:e2e:dev": "start-server-and-test 'vite dev --port 5173' http://localhost:5173 'cypress open --e2e'",
    "type-check": "vue-tsc --build",
    "test:all": "run-p type-check test:unit test:e2e",
    "lint": "eslint .",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@eslint/js": "^9.39.2",
    "@primevue/themes": "^4.5.4",
    "@vueuse/core": "^14.2.1",
    "markdown-it": "^14.1.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "skillfish": "^1.0.28",
    "uuid": "^13.0.0",
    "vue": "^3.5.28",
    "vue-router": "^5.0.2"
  },
  "devDependencies": {
    "@pinia/testing": "^1.0.3",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^27.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.13",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "cypress": "^15.10.0",
    "cypress-real-events": "^1.15.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^5.2.1",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.28.1",
    "jiti": "^2.6.1",
    "jsdom": "^28.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.3",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^3.2.4"
  }
}
